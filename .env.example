# =====================================================
# AMBIENTE
# =====================================================
# Options: development, production, hybrid
NODE_ENV=development

# Porta do servidor HTTP
PORT=3000

# =====================================================
# BANCO DE DADOS
# =====================================================
# Para desenvolvimento local (SQLite): deixe vazio
# Para produção/online (Supabase): preencha com a DATABASE_URL do Supabase
DATABASE_URL=

# =====================================================
# SUPABASE (Produção/Online)
# =====================================================
# Preencha com as credenciais do seu projeto Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =====================================================
# AUTENTICAÇÃO
# =====================================================
# Chave secreta para JWT (use uma string forte e aleatória em produção)
JWT_SECRET=chave-secreta-super-segura-123

# =====================================================
# WEBHOOKS
# =====================================================
# Chave secreta para validar webhooks de pagamento
WEBHOOK_SECRET=

# =====================================================
# WEBSOCKETS
# =====================================================
# Porta do servidor WebSocket
WS_PORT=3001

# =====================================================
# CONFIGURAÇÕES ADICIONAIS
# =====================================================
# URL base da API (para clientes)
API_BASE_URL=http://localhost:3000/api

# Timeout de sessão (em minutos)
SESSION_TIMEOUT=30
